API_PORT=3401
CHAIN_ID=11155111

# Required — server will exit on startup if missing or invalid
REWARD_TOKEN_ADDRESS=0x...
TASK_ESCROW_ADDRESS=0x...
X402_PAY_TO=0x...

# Task creation fee in token atomic units (0 = free during development)
TASK_FEE=0

# x402 Facilitator URL
# Hosted (Base / Base Sepolia only): https://facilitator.x402.org
# Self-hosted: point to your own facilitator instance
FACILITATOR_URL=https://facilitator.x402.org

# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000

# EIP-712 domain params — used only by test-x402.mjs to build payment signatures
# Must match on-chain token contract
REWARD_TOKEN_NAME=USDC
REWARD_TOKEN_VERSION=2
