API_PORT=3401
CHAIN_ID=11155111

# Required — server will exit on startup if missing or invalid
REWARD_TOKEN_ADDRESS=0x...
TASK_ESCROW_ADDRESS=0x...
X402_PAY_TO=0x...

# Task creation fee in token atomic units (0 = free during development)
TASK_FEE=0

# EIP-712 domain params — must match on-chain token contract
# Used to verify EIP-3009 transferWithAuthorization signatures
REWARD_TOKEN_NAME=USDC
REWARD_TOKEN_VERSION=2

# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000
